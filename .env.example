# Spec-Kit: set when not using Git feature branches so plan/tasks/implement target the right feature.
# SPECIFY_FEATURE=001-clearline-mvp

# Supabase (create a project at https://supabase.com)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # server-side only

# Vercel / API (if using serverless API routes)
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# For Vite frontend: VITE_API_URL=http://localhost:3000/api/v1

# Google OAuth (for production sign-in)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional: stock price API for ESPP/RSU estimates (e.g. Alpha Vantage, Yahoo Finance)
# STOCK_API_KEY=
