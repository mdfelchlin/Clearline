{
  "buildCommand": "npm run build --prefix src/frontend",
  "outputDirectory": "src/frontend/dist",
  "installCommand": "npm install && npm install --prefix src/api",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/health", "destination": "/api/index" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ]
}
